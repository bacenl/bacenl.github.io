---
interface Props {
  title: string;
  description: string;
  highlight?: string;
  coverImage: string;
  href: string;
}

const { title, description, highlight, coverImage, href } = Astro.props;
---
<li class="works-list-item">
  <a class="works-list-item-link" href={href}>
    <div class="works-list-item-img-holder">
      <img
        class="works-list-item-img"
        src={coverImage}
        alt={title}
        loading="lazy"
        decoding="async"
      />
    </div>
    <div class="works-list-item-block2">
      <h1 class="works-list-item-title">{title}</h1>
      {highlight && <p class="works-list-item-highlight">{highlight}</p>}
      <h2 class="works-list-item-desc">
        {description.split('\n').map((line, i) => (
          <>{i > 0 && <br />}{line}</>
        ))}
      </h2>
    </div>
  </a>
</li>
