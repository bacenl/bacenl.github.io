---
interface Props {
  title: string;
  description: string;
  coverImage: string;
  href: string;
}

const { title, description, coverImage, href } = Astro.props;
---
<li class="works-list-item">
  <a class="works-list-item-link" href={href}>
    <div class="works-list-item-img-holder">
      <img
        class="works-list-item-img"
        src={coverImage}
        alt={title}
        loading="lazy"
        decoding="async"
      />
    </div>
    <div class="works-list-item-block2">
      <h1 class="works-list-item-title">{title}</h1>
      <h2 class="works-list-item-desc">{description}</h2>
    </div>
  </a>
</li>
