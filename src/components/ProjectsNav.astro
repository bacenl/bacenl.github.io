---
const pathname = Astro.url.pathname;

const isSoftware = pathname === '/projects/software/';
const isDesign = pathname === '/projects/design/';
const isGames = pathname === '/projects/games/';
---
<nav class="work-nav" aria-label="Projects category">
  <a class:list={['nav-item', { active: isSoftware }]} href="/projects/software">SOFTWARE</a>
  <span aria-hidden="true">/</span>
  <a class:list={['nav-item', { active: isDesign }]} href="/projects/design">DESIGN</a>
  <span aria-hidden="true">/</span>
  <a class:list={['nav-item', { active: isGames }]} href="/projects/games">GAMES</a>
</nav>
