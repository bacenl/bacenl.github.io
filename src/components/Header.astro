---
const pathname = Astro.url.pathname;

// Treat "/" and "/index" as the about/home page
const isAbout = pathname === '/';
const isProjects = pathname.startsWith('/projects');
const isBlog = pathname.startsWith('/blog');
const isContact = pathname === '/contact';
---
<header class="site-header">
  <div class="header-inner">
    <a class="header-name" href="/">BACEN</a>
    <nav class="main-nav" aria-label="Main navigation">
      <a class:list={['nav-item', { active: isAbout }]} href="/">ABOUT</a>
      <span aria-hidden="true">/</span>
      <a class:list={['nav-item', { active: isProjects }]} href="/projects/software">PROJECTS</a>
      <span aria-hidden="true">/</span>
      <a class:list={['nav-item', { active: isBlog }]} href="/blog">BLOG</a>
      <span aria-hidden="true">/</span>
      <a class:list={['nav-item', { active: isContact }]} href="/contact">CONTACT</a>
    </nav>
  </div>
</header>
